---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import RatingStars from '../../../components/RatingStars.astro';
import { getCollection, render } from 'astro:content';
import { getCategory } from '../../../data/categories';

export async function getStaticPaths() {
  const reviews = await getCollection('reviews');
  return reviews.map((r) => ({
    params: { category: r.data.category, slug: r.id },
    props: { entry: r },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const catInfo = getCategory(entry.data.category)!;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: entry.data.productName,
    brand: { '@type': 'Brand', name: entry.data.brand },
    image: new URL(entry.data.image, 'https://honestpickreview.com').toString(),
    description: entry.data.shortSummary,
    review: {
      '@type': 'Review',
      reviewRating: {
        '@type': 'Rating',
        ratingValue: entry.data.rating,
        bestRating: '5',
      },
      author: { '@type': 'Organization', name: entry.data.author },
      datePublished: entry.data.publishDate.toISOString().slice(0, 10),
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: entry.data.rating,
      bestRating: '5',
      reviewCount: 1,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://honestpickreview.com/' },
      { '@type': 'ListItem', position: 2, name: catInfo.name, item: `https://honestpickreview.com/reviews/${catInfo.slug}/` },
      { '@type': 'ListItem', position: 3, name: entry.data.productName },
    ],
  },
];

if (entry.data.faq.length > 0) {
  jsonLd.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: entry.data.faq.map((f) => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer },
    })),
  } as any);
}
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.shortSummary}
  image={entry.data.image}
  canonicalPath={`/reviews/${catInfo.slug}/${entry.id}/`}
  jsonLd={jsonLd}
>
  <div class="container" style="padding-top: 24px;">
    <p class="breadcrumbs">
      <a href="/">Home</a> / <a href={`/reviews/${catInfo.slug}/`}>{catInfo.name}</a> / {entry.data.productName}
    </p>
  </div>

  <article class="container" style="max-width: 820px;">
    <span class="badge">{catInfo.name}</span>
    <h1 style="margin-top: 12px;">{entry.data.title}</h1>

    <div style="display: flex; align-items: center; gap: 16px; flex-wrap: wrap; margin-bottom: 20px;">
      <RatingStars rating={entry.data.rating} size="1.1rem" />
      <span style="color: var(--color-text-muted); font-size: 0.9rem;">
        By {entry.data.author} &middot; Updated {(entry.data.updatedDate ?? entry.data.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </span>
    </div>

    <img src={entry.data.image} alt={entry.data.imageAlt} style="border-radius: var(--radius-md); margin-bottom: 24px; aspect-ratio: 16/9; object-fit: cover; width: 100%;" />

    <div class="card quick-info">
      <div>
        <div style="font-size: 0.8rem; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.04em;">Best for</div>
        <div style="font-weight: 700;">{entry.data.bestFor}</div>
      </div>
      <div>
        <div style="font-size: 0.8rem; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.04em;">Price Range</div>
        <div style="font-weight: 700; color: var(--color-primary-dark);">{entry.data.priceRange}</div>
      </div>
      <a href={entry.data.affiliateUrl} class="btn btn-primary quick-info__cta" rel="sponsored noopener" target="_blank">Check Current Price</a>
    </div>

    <style>
      .quick-info {
        padding: 20px;
        margin-bottom: 28px;
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        align-items: center;
        justify-content: space-between;
      }

      @media (max-width: 560px) {
        .quick-info {
          flex-direction: column;
          align-items: stretch;
          gap: 16px;
        }

        .quick-info__cta {
          width: 100%;
          text-align: center;
        }
      }
    </style>

    <div class="prose">
      <Content />
    </div>

    <h2>Specifications</h2>
    <table>
      <tbody>
        {entry.data.specs.map((s) => (
          <tr>
            <th style="width: 40%;">{s.label}</th>
            <td>{s.value}</td>
          </tr>
        ))}
      </tbody>
    </table>

    <div class="card" style="padding: 24px; margin-top: 32px; text-align: center; background: var(--color-surface);">
      <p style="margin-bottom: 12px; font-weight: 600;">Ready to buy the {entry.data.productName}?</p>
      <a href={entry.data.affiliateUrl} class="btn btn-primary" rel="sponsored noopener" target="_blank">Check Current Price</a>
    </div>
  </article>
</BaseLayout>
