---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RatingStars from '../../components/RatingStars.astro';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('bestof');
  return entries.map((e) => ({ params: { slug: e.id }, props: { entry: e } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const items = await Promise.all(
  [...entry.data.items].sort((a, b) => a.rank - b.rank).map(async (item) => {
    const review = await getEntry('reviews', item.reviewSlug);
    return { ...item, review };
  })
);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: entry.data.title,
  itemListElement: items.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.review?.data.productName,
    url: item.review ? `https://honestpickreview.com/reviews/${item.review.data.category}/${item.review.id}/` : undefined,
  })),
};
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  image={entry.data.image}
  canonicalPath={`/best/${entry.id}/`}
  jsonLd={jsonLd}
>
  <div class="container" style="padding-top: 24px;">
    <p class="breadcrumbs"><a href="/">Home</a> / <a href="/best/">Best-Of</a> / {entry.data.title}</p>
  </div>

  <article class="container" style="max-width: 820px;">
    <h1>{entry.data.title}</h1>
    <p style="color: var(--color-text-muted);">{entry.data.description}</p>

    <div class="prose">
      <Content />
    </div>

    <div style="display: grid; gap: 20px; margin-top: 24px;">
      {items.map((item) => item.review && (
        <div class="card" style="display: flex; gap: 16px; padding: 16px; align-items: center;">
          <div style="font-size: 1.6rem; font-weight: 800; color: var(--color-primary); width: 40px; flex-shrink: 0;">#{item.rank}</div>
          <img src={item.review.data.image} alt={item.review.data.imageAlt} style="width: 120px; aspect-ratio: 4/3; object-fit: cover; border-radius: var(--radius-sm); flex-shrink: 0;" />
          <div style="flex: 1;">
            <h3 style="margin: 0 0 4px;"><a href={`/reviews/${item.review.data.category}/${item.review.id}/`}>{item.review.data.productName}</a></h3>
            <RatingStars rating={item.review.data.rating} size="0.85rem" />
            <p style="margin: 6px 0 0; color: var(--color-text-muted); font-size: 0.9rem;">{item.blurb}</p>
          </div>
          <a href={`/reviews/${item.review.data.category}/${item.review.id}/`} class="btn btn-secondary" style="flex-shrink: 0;">Read Review</a>
        </div>
      ))}
    </div>
  </article>
</BaseLayout>
