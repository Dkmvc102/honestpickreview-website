---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const bestof = (await getCollection('bestof')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<BaseLayout title="Best-Of Roundups" description="Ranked best-of product roundups across every category on HonestPickReview.">
  <div class="container" style="padding-top: 24px;">
    <p class="breadcrumbs"><a href="/">Home</a> / Best-Of Roundups</p>
  </div>
  <section class="container" style="padding-bottom: 16px;">
    <h1>Best-Of Roundups</h1>
    <p style="color: var(--color-text-muted); max-width: 640px;">Ranked picks for when you don't have time to compare every option in a category yourself.</p>
  </section>
  <section class="section container" style="padding-top: 0;">
    <div class="grid grid-3">
      {bestof.map((b) => (
        <a href={`/best/${b.id}/`} class="card" style="display: block; color: inherit;">
          <img src={b.data.image} alt={b.data.imageAlt} loading="lazy" style="aspect-ratio: 4/3; object-fit: cover; width: 100%;" />
          <div style="padding: 16px;">
            <h3 style="font-size: 1.05rem; margin: 0 0 6px;">{b.data.title}</h3>
            <p style="color: var(--color-text-muted); font-size: 0.88rem; margin: 0;">{b.data.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
