---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy" description="HonestPickReview's privacy policy covering data collection, cookies, and third-party services.">
  <div class="container" style="padding-top: 24px;">
    <p class="breadcrumbs"><a href="/">Home</a> / Privacy Policy</p>
  </div>
  <article class="container prose" style="max-width: 720px; padding-bottom: 48px;">
    <h1>Privacy Policy</h1>
    <p><em>Last updated: [insert date before publishing]</em></p>
    <p>
      This is placeholder content. Before launching publicly, replace this page with a complete privacy
      policy covering:
    </p>
    <ul>
      <li>What data is collected (analytics, cookies, contact form submissions)</li>
      <li>Third-party services used (e.g., Google Analytics, affiliate networks, ad networks)</li>
      <li>How users can opt out of tracking or request data deletion</li>
      <li>Contact information for privacy-related inquiries</li>
      <li>Compliance notes for applicable regulations (e.g., GDPR, CCPA) if you have visitors from those regions</li>
    </ul>
    <p>
      Many affiliate programs and ad networks (including Google AdSense and Amazon Associates) require a
      compliant privacy policy to be live before approving your account — consider using a privacy policy
      generator or consulting legal counsel to finalize this page.
    </p>
  </article>
</BaseLayout>
