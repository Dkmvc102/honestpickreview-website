---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Terms of Use" description="Terms of use for HonestPickReview.com.">
  <div class="container" style="padding-top: 24px;">
    <p class="breadcrumbs"><a href="/">Home</a> / Terms of Use</p>
  </div>
  <article class="container prose" style="max-width: 720px; padding-bottom: 48px;">
    <h1>Terms of Use</h1>
    <p><em>Last updated: [insert date before publishing]</em></p>
    <p>
      This is placeholder content. Before launching publicly, replace this page with complete terms of use
      covering:
    </p>
    <ul>
      <li>Acceptable use of the site and content</li>
      <li>Intellectual property / content ownership</li>
      <li>Disclaimer of warranties on product information accuracy (prices and availability change)</li>
      <li>Limitation of liability</li>
      <li>Governing law and jurisdiction</li>
    </ul>
  </article>
</BaseLayout>
