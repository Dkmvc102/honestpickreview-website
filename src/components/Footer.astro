---
import { categories } from '../data/categories';
const year = new Date().getFullYear();
---

<footer style="background: rgba(247, 248, 250, 0.55); backdrop-filter: blur(2px); border-top: 1px solid var(--color-border); margin-top: 64px;">
  <div class="container section" style="padding-bottom: 32px;">
    <div class="grid grid-3" style="margin-bottom: 32px;">
      <div>
        <div style="font-weight: 800; font-size: 1.1rem; margin-bottom: 10px;">
          <span style="color: var(--color-primary);">Honest</span>PickReview
        </div>
        <p style="color: var(--color-text-muted); font-size: 0.9rem;">
          Independent, research-driven reviews of physical products to help you buy with confidence.
        </p>
      </div>
      <div>
        <div style="font-weight: 700; margin-bottom: 10px;">Categories</div>
        <ul style="list-style: none; padding: 0; margin: 0; display: grid; gap: 6px; font-size: 0.9rem;">
          {categories.map((c) => (
            <li><a href={`/reviews/${c.slug}/`}>{c.name}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <div style="font-weight: 700; margin-bottom: 10px;">Company</div>
        <ul style="list-style: none; padding: 0; margin: 0; display: grid; gap: 6px; font-size: 0.9rem;">
          <li><a href="/about/">About Us</a></li>
          <li><a href="/how-we-review/">How We Review</a></li>
          <li><a href="/affiliate-disclosure/">Affiliate Disclosure</a></li>
          <li><a href="/privacy-policy/">Privacy Policy</a></li>
          <li><a href="/terms/">Terms of Use</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>
      </div>
    </div>
    <div style="border-top: 1px solid var(--color-border); padding-top: 20px; font-size: 0.82rem; color: var(--color-text-muted);">
      &copy; {year} HonestPickReview.com. All rights reserved. As an affiliate, we may earn a commission from qualifying purchases made through links on this site.
    </div>
  </div>
</footer>
