---
import { categories } from '../data/categories';
---

<header style="border-bottom: 1px solid var(--color-border); background: var(--color-bg); position: sticky; top: 0; z-index: 20;">
  <div class="container" style="display: flex; align-items: center; justify-content: space-between; padding-top: 16px; padding-bottom: 16px; gap: 24px;">
    <a href="/" style="font-weight: 800; font-size: 1.25rem; color: var(--color-text); display: flex; align-items: center; gap: 6px;">
      <span style="color: var(--color-primary);">Honest</span>PickReview
    </a>
    <nav style="display: flex; gap: 20px; flex-wrap: wrap; font-size: 0.92rem; font-weight: 600;">
      {categories.slice(0, 4).map((c) => (
        <a href={`/reviews/${c.slug}/`} style="color: var(--color-text);">{c.name}</a>
      ))}
      <a href="/blog/" style="color: var(--color-text);">Buying Guides</a>
      <a href="/how-we-review/" style="color: var(--color-text);">How We Review</a>
    </nav>
  </div>
</header>
